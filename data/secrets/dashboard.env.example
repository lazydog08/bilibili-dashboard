# Copy this file to ~/.config/bilibili-dashboard/dashboard.env on the NAS and
# fill only the values you actually use. Do not keep real Cookie/token values
# inside the project directory.

DASHBOARD_MODE=bilibili-only
DASHBOARD_TIMEZONE=Asia/Shanghai
DASHBOARD_UPDATE_INTERVAL_MINUTES=30
DASHBOARD_PAGE_REFRESH_SECONDS=1800
DASHBOARD_UPDATE_LOG=data/logs/nas-update.log
RUN_DASHBOARD_TESTS=0
ENABLE_FEISHU_SYNC=0
DISABLE_BARK=0
DASHBOARD_GIT_PUSH=0

# Local NAS dashboard output. Point this to your NAS web directory.
DASHBOARD_PUBLISH_DIR=/volume1/web/bilibili-dashboard
# Finder button shown on the dashboard. Use an smb:// URL that macOS can open.
DASHBOARD_NAS_FINDER_URL=smb://192.168.31.68/0_视频制作总盘/1_懒狗小黑

# NAS -> GitHub Pages cloud publishing.
# The recommended NAS cron runs every 30 minutes and refreshes data before each push.
DASHBOARD_CLOUD_REMOTE_NAME=origin
DASHBOARD_CLOUD_REMOTE_URL=git@github.com:lazydog08/bilibili-dashboard.git
DASHBOARD_CLOUD_BRANCH=main
DASHBOARD_GIT_PULL_BEFORE_PUSH=1
DASHBOARD_CLOUD_UPDATE_BEFORE_PUSH=1
DASHBOARD_GIT_NAME=UGREEN NAS Dashboard Bot
DASHBOARD_GIT_EMAIL=nas-dashboard@local

ENABLE_BILIBILI_FETCH=1
BILIBILI_ENABLED=true
BILIBILI_ACCOUNT_ID=516185777
BILIBILI_COOKIE=

DOUYIN_ENABLED=true
DOUYIN_ACCOUNT_ID=
DOUYIN_ACCESS_TOKEN=
DOUYIN_OPEN_ID=
DOUYIN_OFFICIAL_DATA_URL=
DOUYIN_COOKIE=
DOUYIN_DATA_URL=
DOUYIN_EXTRA_HEADERS_JSON=

XIAOHONGSHU_ENABLED=true
XIAOHONGSHU_ACCOUNT_ID=
XIAOHONGSHU_ACCESS_TOKEN=
XIAOHONGSHU_OPEN_ID=
XIAOHONGSHU_OFFICIAL_DATA_URL=
XIAOHONGSHU_COOKIE=
XIAOHONGSHU_DATA_URL=
XIAOHONGSHU_CONTENT_DATA_URL=
XIAOHONGSHU_EXTRA_HEADERS_JSON=

BARK_DEVICE_KEY=
BARK_GROUP=数据看板
BARK_SOUND=minuet
