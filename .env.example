BARK_DEVICE_KEY=
BARK_GROUP=数据看板
BARK_SOUND=minuet

DASHBOARD_UPDATE_TIMES=12:30,20:00
DASHBOARD_TIMEZONE=Asia/Shanghai
LOG_RETENTION_DAYS=30
PLATFORM_CONTENT_LIMIT=50
MANUAL_PLATFORM_ENABLED=true
MANUAL_PLATFORM_DATA_PATH=data/manual_platform_metrics.json

# NAS / local scheduler
DASHBOARD_MODE=live
DASHBOARD_REPO_DIR=
DASHBOARD_ENV_FILE=~/.config/bilibili-dashboard/dashboard.env
DASHBOARD_UPDATE_LOG=data/logs/nas-update.log
RUN_DASHBOARD_TESTS=0
AUTO_CREATE_VENV=1
ENABLE_FEISHU_SYNC=0
DISABLE_BARK=0
DASHBOARD_GIT_PUSH=0
DASHBOARD_PUBLISH_DIR=
DASHBOARD_NAS_FINDER_URL=smb://192.168.31.68/0_视频制作总盘/1_懒狗小黑

# Comment radar
ENABLE_COMMENT_INSIGHTS=0
ENABLE_COMMENT_FETCH=0
COMMENT_PRIVATE_PATH=data/private/comments.json
COMMENT_VIDEO_LIMIT=10
COMMENT_RECENT_PAGE_SIZE=20
COMMENT_RANKED_VIDEO_LIMIT=3
COMMENT_RANKED_PAGE_SIZE=20
COMMENT_SCORE_PUSH_THRESHOLD=70
COMMENT_RETENTION_DAYS=14

BILIBILI_ENABLED=true
BILIBILI_ACCOUNT_ID=
ENABLE_BILIBILI_FETCH=0
BILIBILI_COOKIE=

DOUYIN_ENABLED=true
DOUYIN_ACCOUNT_ID=
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
